{
  "_source": "AI-BRAIN-API v1.1 + HANDOFF-TO-INTEGRATORS v1.1 (CloudCost, 2026-04-21)",
  "_safety": "AI-safe read-only surface. Writes / Azure deploy / credentials / exports / sync triggers explicitly excluded. Enforced by scripts/import_cloudcost_tools.py.",
  "base_url_env": "CLOUDCOST_API_BASE",
  "timeout_sec": 45,
  "roles": ["cloud_admin", "cloud_ops", "cloud_finance", "cloud_viewer"],
  "tools": [
    {
      "name": "cloud_cost.health",
      "display_name": "CloudCost Health",
      "description": "用途: 探测 CloudCost 后端连通性。\n何时使用: 对话前做一次快速自检。\n返回: {status:'ok'}。",
      "method": "GET",
      "path": "/api/health",
      "input_schema": {"type": "object", "additionalProperties": false, "properties": {}},
      "roles": ["cloud_admin", "cloud_ops", "cloud_finance", "cloud_viewer"]
    },
    {
      "name": "cloud_cost.auth_me",
      "display_name": "CloudCost 当前身份与可见范围",
      "description": "用途: 返回当前 bearer token 绑定的用户信息与 visible_cloud_account_ids。\n何时使用: 回答问题前确认数据口径 (admin 全量 / null / [] / [ids]).\n出参: id/username/email/display_name/roles/visible_cloud_account_ids。",
      "method": "GET",
      "path": "/api/auth/me",
      "input_schema": {"type": "object", "additionalProperties": false, "properties": {}},
      "roles": ["cloud_admin", "cloud_ops", "cloud_finance", "cloud_viewer"]
    },
    {
      "name": "cloud_cost.sync_last",
      "display_name": "CloudCost 最近同步时间",
      "description": "用途: 查询 CloudCost 最后一次成功同步的 ISO8601 时间 (无时区)。\n何时使用: 先确认数据新鲜度再讨论费用。\n出参: {last_sync: string|null}.",
      "method": "GET",
      "path": "/api/sync/last",
      "input_schema": {"type": "object", "additionalProperties": false, "properties": {}},
      "roles": ["cloud_admin", "cloud_ops"]
    },

    {
      "name": "cloud_cost.dashboard_bundle",
      "display_name": "CloudCost 首页聚合 Bundle",
      "description": "用途: 单次拿首页级总览 (overview + trend + by_provider + by_service).\n何时使用: '本月云成本多少' 类宽口径问题.\n参数: month YYYY-MM 必填; granularity (daily/weekly/monthly, 默认 daily); service_limit 1-100 默认 10.",
      "method": "GET",
      "path": "/api/dashboard/bundle",
      "param_map": {"month": "query", "granularity": "query", "service_limit": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "granularity": {"type": "string", "enum": ["daily", "weekly", "monthly"], "default": "daily"},
          "service_limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 10}
        },
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_overview",
      "display_name": "CloudCost 月度总览卡片",
      "description": "用途: 只拿 overview 卡片 (total_cost, prev_month_cost, mom_change_pct, active_projects).\n参数: month YYYY-MM 必填.",
      "method": "GET",
      "path": "/api/dashboard/overview",
      "param_map": {"month": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {"month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"}},
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_trend",
      "display_name": "CloudCost 费用趋势",
      "description": "用途: 多月区间内的费用趋势 (按 daily/weekly/monthly 粒度).\n参数: start / end 都是 YYYY-MM; granularity 默认 daily.",
      "method": "GET",
      "path": "/api/dashboard/trend",
      "param_map": {"start": "query", "end": "query", "granularity": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "start": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "end": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "granularity": {"type": "string", "enum": ["daily", "weekly", "monthly"], "default": "daily"}
        },
        "required": ["start", "end"]
      }
    },
    {
      "name": "cloud_cost.dashboard_by_provider",
      "display_name": "CloudCost 按云厂商拆分",
      "description": "用途: 按 aws/gcp/azure/taiji 的月度费用与占比.\n参数: month YYYY-MM.",
      "method": "GET",
      "path": "/api/dashboard/by-provider",
      "param_map": {"month": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {"month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"}},
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_by_category",
      "display_name": "CloudCost 按费用分类拆分",
      "description": "用途: 按 categories 返回原始成本 / markup_rate / 加价后金额.\n参数: month YYYY-MM.",
      "method": "GET",
      "path": "/api/dashboard/by-category",
      "param_map": {"month": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {"month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"}},
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_by_project",
      "display_name": "CloudCost 按项目 Top N",
      "description": "用途: 月度 Top N 项目费用列表 (云厂商侧 external_project_id).\n参数: month YYYY-MM; limit 1-100 默认 10.",
      "method": "GET",
      "path": "/api/dashboard/by-project",
      "param_map": {"month": "query", "limit": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 10}
        },
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_by_service",
      "display_name": "CloudCost 按服务 Top N",
      "description": "用途: 月度 Top N 服务 (product) 费用与占比.\n参数: month YYYY-MM; provider 可选 (aws/gcp/azure/taiji); limit 1-100.",
      "method": "GET",
      "path": "/api/dashboard/by-service",
      "param_map": {"month": "query", "provider": "query", "limit": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "provider": {"type": "string", "enum": ["aws", "gcp", "azure", "taiji"]},
          "limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 10}
        },
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_by_region",
      "display_name": "CloudCost 按区域拆分",
      "description": "用途: 月度 region 维度的费用列表.\n参数: month YYYY-MM.",
      "method": "GET",
      "path": "/api/dashboard/by-region",
      "param_map": {"month": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {"month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"}},
        "required": ["month"]
      }
    },
    {
      "name": "cloud_cost.dashboard_top_growth",
      "display_name": "CloudCost 增长排行",
      "description": "用途: 按项目列出 growth_pct 最高的 N 个 (本周期 vs 上周期).\n参数: period 默认 '7d'; limit 1-50.",
      "method": "GET",
      "path": "/api/dashboard/top-growth",
      "param_map": {"period": "query", "limit": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "period": {"type": "string", "default": "7d"},
          "limit": {"type": "integer", "minimum": 1, "maximum": 50, "default": 10}
        }
      }
    },
    {
      "name": "cloud_cost.dashboard_unassigned",
      "display_name": "CloudCost 未归属项目",
      "description": "用途: 列出账单里存在但未与本地 projects 关联的外部项目.\n参数: month YYYY-MM.",
      "method": "GET",
      "path": "/api/dashboard/unassigned",
      "param_map": {"month": "query"},
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {"month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"}},
        "required": ["month"]
      }
    },

    {
      "name": "cloud_cost.metering_summary",
      "display_name": "CloudCost Metering 汇总",
      "description": "用途: 日期区间/provider/服务/账号作用域内的 total_cost / total_usage / record_count / service_count.\n金额 & 用量为 string (Decimal), 调用方自行 float()。\n多选参数: account_ids / products 使用重复 query 语法.",
      "method": "GET",
      "path": "/api/metering/summary",
      "param_map": {
        "date_start": "query", "date_end": "query",
        "provider": "query", "product": "query", "products": "query",
        "account_id": "query", "account_ids": "query",
        "supply_source_id": "query", "supplier_name": "query", "data_source_id": "query"
      },
      "input_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "date_start": {"type": "string", "format": "date"},
          "date_end": {"type": "string", "format": "date"},
          "provider": {"type": "string", "enum": ["aws", "gcp", "azure", "taiji"]},
          "product": {"type": "string"},
          "products": {"type": "array", "items": {"type": "string"}, "description": "重复 query 语法; 非空时覆盖 product"},
          "account_id": {"type": "integer"},
          "account_ids": {"type": "array", "items": {"type": "integer"}, "description": "重复 query 语法; 非空时覆盖 account_id"},
          "supply_source_id": {"type": "integer"},
          "supplier_name": {"type": "string"},
          "data_source_id": {"type": "integer"}
        }
      }
    },
    {
      "name": "cloud_cost.metering_daily",
      "display_name": "CloudCost Metering 按日",
