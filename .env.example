# ─── App ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SERVER_NAME=chat-gw
SERVER_VERSION=0.1.0

# ─── JWT Auth ─────────────────────────────────────────────────────────
# Dev mode (APP_ENV=development|staging):
#   Set JWT_DEV_SECRET, leave JWKS_URL empty. Gateway uses HS256.
# Prod mode (APP_ENV=production):
#   JWT_DEV_SECRET MUST be empty (startup fails otherwise).
#   Set JWKS_URL + JWT_ISSUER + JWT_AUDIENCE; Gateway uses RS256 via Casdoor JWKS.
JWT_DEV_SECRET=dev-secret-change-me-in-production
JWT_DEV_ALGORITHM=HS256

JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=chat-gw
JWT_LEEWAY_SEC=30
JWKS_CACHE_TTL_SEC=3600
JWKS_REFRESH_COOLDOWN_SEC=30

# ─── Casdoor (prod fallback when token claim is empty) ────────────────
CASDOOR_ENDPOINT=
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORG=
CASDOOR_APP_NAME=chat-gw
CASDOOR_ROLES_CLAIM=roles

# ─── Postgres ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chatgw:chatgw@postgres:5432/chat_gw
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
POSTGRES_USER=chatgw
POSTGRES_PASSWORD=chatgw
POSTGRES_DB=chat_gw

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
ROLE_CACHE_TTL_SEC=60

# ─── Registry ─────────────────────────────────────────────────────────
REGISTRY_CACHE_TTL_SEC=30

# ─── HTTP dispatcher defaults ─────────────────────────────────────────
HTTP_DEFAULT_TIMEOUT_SEC=30
HTTP_DEFAULT_RETRIES=2
HTTP_RETRY_BACKOFF_BASE_SEC=0.25

# ─── MCP proxy (remote MCP servers) ───────────────────────────────────
MCP_PROXY_DEFAULT_TIMEOUT_SEC=60

# ─── Daytona sandbox (sandbox.run_python) ─────────────────────────────
DAYTONA_DEFAULT_TIMEOUT_SEC=60
DAYTONA_MAX_TIMEOUT_SEC=300

# ─── MCP transports ───────────────────────────────────────────────────
ENABLE_MCP_SSE=true

# ─── Downstream service secrets (PLACEHOLDERS — replace in real envs) ───
KB_AGENT_URL=https://kb-agent.example.com
KB_AGENT_API_KEY=REPLACE_ME
GONGDAN_API_BASE=https://gongdan.example.com
GONGDAN_API_KEY=REPLACE_ME
# SuperOps (sales.*) is user_passthrough — Casdoor JWT forwarded; no service key.
SUPER_OPS_API_BASE=https://xiaoshou-api.example.com/api/external
SERPER_BASE=https://google.serper.dev
SERPER_API_KEY=REPLACE_ME
DOC_CREATOR_BASE=https://doc-creator.example.com
DOC_CREATOR_API_KEY=REPLACE_ME
DAYTONA_API_BASE=https://app.daytona.io/api
DAYTONA_API_TOKEN=REPLACE_ME
JINA_MCP_URL=https://mcp.jina.ai/sse
JINA_API_KEY=REPLACE_ME

# ─── CloudCost (user_passthrough; no service key ever stored here) ────
CLOUDCOST_API_BASE=https://cloudcost.example.com
